# REQUIRES-PROPERTIES-FILE - # Do not remove this comment!
CREATE OR REPLACE DATASOURCE JSON denodo_mpp_api
    ROUTE HTTP 'http.ApacheHttpClientConnection,120000' GET '${databases.admin_denodo_mpp.datasources.json.denodo_mpp_api.ROUTE.HTTP.URL}'
 AUTHENTICATION BASIC ( 
      USER '${databases.admin_denodo_mpp.datasources.json.denodo_mpp_api.ROUTE.HTTP.USER}'
      PASSWORD '${databases.admin_denodo_mpp.datasources.json.denodo_mpp_api.ROUTE.HTTP.PASSWORD}' ${databases.admin_denodo_mpp.datasources.json.denodo_mpp_api.ROUTE.HTTP.PASSWORD.ENCRYPTED} )
    PROXY OFF;

