CREATE OR REPLACE VIEW denodo_mpp_workers_status FOLDER = '/mpp cluster status' AS SELECT denodo_mpp_worker_status.workerid AS workerid, denodo_mpp_worker_status.nodeid AS nodeid, denodo_mpp_worker_status.nodeversion AS nodeversion, denodo_mpp_worker_status.environment AS environment, denodo_mpp_worker_status.coordinator AS coordinator, denodo_mpp_worker_status.uptime AS uptime, denodo_mpp_worker_status.externaladdress AS externaladdress, denodo_mpp_worker_status.internaladdress AS internaladdress, denodo_mpp_worker_status.memoryinfo AS memoryinfo, denodo_mpp_worker_status.processors AS processors, denodo_mpp_worker_status.processcpuload AS processcpuload, denodo_mpp_worker_status.systemcpuload AS systemcpuload, denodo_mpp_worker_status.heapused AS heapused, denodo_mpp_worker_status.heapavailable AS heapavailable, denodo_mpp_worker_status.nonheapused AS nonheapused, denodo_mpp_workers.node_id AS node_id, denodo_mpp_workers.http_uri AS http_uri, denodo_mpp_workers.node_version AS node_version, denodo_mpp_workers.state AS state FROM denodo_mpp_workers AS denodo_mpp_workers INNER JOIN denodo_mpp_worker_status AS denodo_mpp_worker_status ON denodo_mpp_workers.node_id = denodo_mpp_worker_status.workerid ;

